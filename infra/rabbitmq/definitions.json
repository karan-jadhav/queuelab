{
  "vhosts": [
    {
      "name": "/"
    }
  ],
  "permissions": [
    {
      "user": "guest",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "exchanges": [
    {
      "name": "queuelab.jobs",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "queuelab.jobs.dlx",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "queuelab.jobs.main",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "queuelab.jobs.dlx",
        "x-dead-letter-routing-key": "dead"
      }
    },
    {
      "name": "queuelab.jobs.dead",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "queuelab.jobs",
      "vhost": "/",
      "destination": "queuelab.jobs.main",
      "destination_type": "queue",
      "routing_key": "job",
      "arguments": {}
    },
    {
      "source": "queuelab.jobs.dlx",
      "vhost": "/",
      "destination": "queuelab.jobs.dead",
      "destination_type": "queue",
      "routing_key": "dead",
      "arguments": {}
    }
  ]
}
